(subdir quickjs
 (include_subdirs unqualified)
 (dirs . include)
 (foreign_library
  (archive_name quickjs)
  (language c)
  (names cutils dtoa libregexp libunicode quickjs-libc quickjs )
  (include_dirs include)
  (flags :standard -Wno-array-bounds -Wno-format-truncation -Wno-infinite-recursion -fwrapv 
         -D_GNU_SOURCE "-DCONFIG_VERSION=\"2025-09-13\"" -O2 -Wno-array-bounds -Wno-format-truncation 
         -Wno-infinite-recursion )))


